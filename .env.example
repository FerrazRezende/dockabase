# =============================================================================
# DOCKABASE - Environment Configuration
# =============================================================================
# Compartilhado por Docker Compose e Laravel 12

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="DockaBase"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Porta exposta pelo Nginx
APP_PORT=80

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=dockabase
DB_USERNAME=dockabase
DB_PASSWORD=secret

# =============================================================================
# PGADMIN
# =============================================================================
PGADMIN_EMAIL=admin@dockabase.local
PGADMIN_PASSWORD=secret
PGADMIN_PORT=5050

# =============================================================================
# CACHE & SESSION (Redis)
# =============================================================================
CACHE_STORE=redis
CACHE_PREFIX=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# =============================================================================
# QUEUE (Redis)
# =============================================================================
QUEUE_CONNECTION=redis

# =============================================================================
# BROADCASTING (Redis)
# =============================================================================
BROADCAST_CONNECTION=redis

# =============================================================================
# REDIS
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# =============================================================================
# RABBITMQ
# =============================================================================
RABBITMQ_USER=dockabase
RABBITMQ_PASSWORD=secret
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# =============================================================================
# FILESYSTEM (MinIO)
# =============================================================================
FILESYSTEM_DISK=local

MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=dockabase
MINIO_ROOT_PASSWORD=secret123456
MINIO_BUCKET=dockabase
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_PATH_STYLE_ENDPOINT=true
MINIO_REGION=us-east-1

# AWS S3 (produção)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# MAIL
# =============================================================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@dockabase.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# LARAVEL OCTANE
# =============================================================================
# OCTANE_SERVER=roadrunner
# OCTANE_SERVER=swoole

# =============================================================================
# FEATURE FLAGS
# =============================================================================
PENNANT_STORE=database

# =============================================================================
# VITE
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
